# Caddy reverse proxy for a DigiAssetPoolServer.
#
# What this does:
#   - Serves a static landing page (./site) at "/" and any non-API path.
#   - Reverse-proxies the pool wire-protocol routes to the local
#     DigiAssetPoolServer.exe listening on 127.0.0.1:14028.
#   - Obtains and auto-renews a TLS certificate for the domain (Let's Encrypt).
#
# Requirements:
#   - A DNS A/AAAA record for the domain pointing at this server's public IP.
#   - Inbound TCP 80 and 443 reachable from the internet (Caddy needs 80 for the
#     ACME HTTP challenge and 443 to serve HTTPS).
#   - DigiAssetPoolServer.exe running locally with poolport=14028.
#
# setup-caddy.ps1 rewrites the placeholders below (DOMAIN, SITE_ROOT, POOLPORT,
# CADDY_DATA) before launching Caddy. If you edit this by hand, set them yourself.

# Global options. Persist certificates + the ACME account key in a FIXED shared
# folder so the SAME cert is reused whether Caddy runs manually (your user
# profile) or as the SYSTEM scheduled task (the system profile). Without this,
# each runs under a different profile with its own EMPTY cert store, so the
# SYSTEM task re-requests a cert every boot and fails - the classic "works when I
# run it by hand, dies as a task" symptom.
{
	storage file_system {$CADDY_DATA}
}

{$DOMAIN} {
	encode gzip

	# Pool wire-protocol + stats + peer endpoints -> the pool server exe.
	# Keep this list in sync with the routes in pool/PoolServer.cpp.
	# /peer/* is how peer pools reach each other over HTTPS (token-gated).
	@api path /permanent/* /list/* /keepalive /nodes.json /map.json /bad.json /pool/stats.json /peer/*
	handle @api {
		reverse_proxy 127.0.0.1:{$POOLPORT}
	}

	# Everything else -> the static landing page.
	handle {
		root * {$SITE_ROOT}
		file_server
	}

	# Don't leak the reverse-proxy target in error pages.
	header -Server
}
